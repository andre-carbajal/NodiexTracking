generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id              String          @id @default(uuid())
  username        String          @unique
  hashPassword    String          @map("hash_password")
  estado          String          @default("activo")
  failedAttempts  Int             @default(0) @map("failed_attempts")
  lockedUntil     DateTime?       @map("locked_until")
  ultimoAcceso    DateTime?       @map("ultimo_acceso")
  createdAt       DateTime        @default(now()) @map("created_at")
  roles           UsuarioRol[]
  sesiones        Sesion[]
  despachos       Despacho[]
  bitacoraEventos BitacoraEvento[]

  @@map("usuarios")
}

model Rol {
  id          String       @id @default(uuid())
  nombreRol   String       @unique @map("nombre_rol")
  descripcion String?
  usuarios    UsuarioRol[]
  permisos    Permiso[]

  @@map("roles")
}

model UsuarioRol {
  usuarioId String  @map("usuario_id")
  rolId     String  @map("rol_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol       Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@id([usuarioId, rolId])
  @@map("usuarios_roles")
}

model Permiso {
  id      String @id @default(uuid())
  recurso String
  accion  String
  rolId   String @map("rol_id")
  rol     Rol    @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@unique([rolId, recurso, accion])
  @@map("permisos")
}

model Sesion {
  id              String   @id @default(uuid())
  tokenJwt        String   @map("token_jwt") @db.Text
  fechaExpiracion DateTime @map("fecha_expiracion")
  ipOrigen        String?  @map("ip_origen")
  usuarioId       String   @map("usuario_id")
  createdAt       DateTime @default(now()) @map("created_at")
  usuario         Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sesiones")
}

model Despacho {
  id                 String           @id @default(uuid())
  codigoTracking     String           @unique @map("codigo_tracking")
  cliente            String
  destino            String
  producto           String
  estadoActual       String           @map("estado_actual")
  fechaRegistro      DateTime         @default(now()) @map("fecha_registro")
  fechaActualizacion DateTime         @default(now()) @map("fecha_actualizacion")
  activo             Boolean          @default(true)
  usuarioId          String?          @map("usuario_id")
  usuario            Usuario?         @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  estados            EstadoDespacho[]

  @@map("despachos")
}

model EstadoDespacho {
  id          String    @id @default(uuid())
  estado      String
  fechaHora   DateTime  @default(now()) @map("fecha_hora")
  observacion String?
  responsable String
  despachoId  String    @map("despacho_id")
  despacho    Despacho  @relation(fields: [despachoId], references: [id], onDelete: Cascade)

  @@map("estados_despacho")
}

model Producto {
  id                String                  @id @default(uuid())
  activo            Boolean                 @default(true)
  imagenUrl         String?                 @map("imagen_url")
  estadoPublicacion String                  @default("borrador") @map("estado_publicacion")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  traducciones      Traduccion[]
  presentaciones    PresentacionLogistica[]

  @@map("productos")
}

model PresentacionLogistica {
  id         String   @id @default(uuid())
  tipoUnidad String   @map("tipo_unidad")
  capacidad  String?
  productoId String   @map("producto_id")
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  precios    Precio[]

  @@map("presentaciones_logisticas")
}

model Precio {
  id             String                 @id @default(uuid())
  moneda         String
  monto          Decimal                @db.Decimal(12, 2)
  vigencia       DateTime?
  presentacionId String                 @map("presentacion_id")
  presentacion   PresentacionLogistica  @relation(fields: [presentacionId], references: [id], onDelete: Cascade)

  @@unique([presentacionId, moneda])
  @@map("precios")
}

model Certificacion {
  id              String   @id @default(uuid())
  tipo            String
  fechaEmision    DateTime? @map("fecha_emision")
  fechaVencimiento DateTime @map("fecha_vencimiento")
  urlEvidencia    String?  @map("url_evidencia")
  evidencia       String?
  estadoVigencia  String   @map("estado_vigencia")
  publicado       Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("certificaciones")
}

model Contenido {
  id                 String       @id @default(uuid())
  seccion            String
  estadoPublicacion  String       @default("borrador") @map("estado_publicacion")
  fechaActualizacion DateTime     @updatedAt @map("fecha_actualizacion")
  traducciones       Traduccion[]

  @@map("contenidos")
}

model Traduccion {
  id         String     @id @default(uuid())
  idioma     String
  titulo     String?
  cuerpo     String?
  estado     String     @default("borrador")
  contenidoId String?   @map("contenido_id")
  productoId  String?   @map("producto_id")
  contenido   Contenido? @relation(fields: [contenidoId], references: [id], onDelete: Cascade)
  producto    Producto?  @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([productoId, idioma])
  @@unique([contenidoId, idioma])
  @@map("traducciones")
}

model BitacoraEvento {
  id        String   @id @default(uuid())
  entidad   String
  accion    String
  fechaHora DateTime @default(now()) @map("fecha_hora")
  usuarioId String?  @map("usuario_id")
  usuarioNombre String? @map("usuario_nombre")
  detalle   Json
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([entidad, accion, fechaHora])
  @@map("bitacora_eventos")
}
